# ============ Auth.js / Office 365 SSO (Microsoft Entra ID) ============
# From Entra App registration (see README "Office 365 SSO setup")
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Issuer = https://login.microsoftonline.com/<TENANT_ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the portal (https in prod). Used for OIDC redirects.
AUTH_URL=http://localhost:3000
# Trust the host header behind a reverse proxy
AUTH_TRUST_HOST=true

# ============ Database (AWS Postgres reached via Tailscale tunnel) ============
# In prod the host is the Tailscale name/IP of the AWS box; locally it's localhost.
DATABASE_URL=postgresql://portal_app:CHANGE_ME@localhost:5432/it_ticketing_system
# TLS: set to "verify-full" in prod with PGSSLROOTCERT pointing at the AWS CA bundle.
PGSSLMODE=disable
# PGSSLROOTCERT=/app/certs/aws-rds-ca.pem

# ============ App ============
# IST is read from system_config.business_timezone; this is a fallback only.
DEFAULT_TIMEZONE=Asia/Kolkata
NODE_ENV=development

# ============ n8n integration ============
# Webhook Trigger URL that sends the customer closure email when a ticket is
# closed from the portal (a direct DB close does not generate the inbound email
# n8n normally listens for). If unset, closing still works but no email is sent.
N8N_CLOSE_WEBHOOK_URL=https://<your-n8n-host>/webhook/portal-ticket-closed
# Webhook Trigger URL that emails the newly-assigned agent when a ticket is
# reassigned from the portal (portal assignments bypass the inbound-email n8n
# path, so the agent gets no ping without this). If unset, reassigning still
# works but no notification is sent. Self-assignments are never notified.
N8N_ASSIGN_WEBHOOK_URL=https://<your-n8n-host>/webhook/portal-ticket-assigned
# Webhook Trigger URL for portal status events (On Hold, custom turnaround). One
# endpoint; the JSON `event` field selects the n8n branch + recipients. On Hold
# emails requester+manager; turnaround emails requester+manager+assigned agent.
N8N_STATUS_EVENT_WEBHOOK_URL=https://<your-n8n-host>/webhook/portal-ticket-status-event
# Optional shared secret sent as the X-Webhook-Token header; verify it in n8n.
N8N_WEBHOOK_TOKEN=<random-token>
